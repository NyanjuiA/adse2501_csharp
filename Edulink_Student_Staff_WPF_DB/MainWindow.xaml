<Window x:Class="Edulink_Student_Staff_WPF_DB.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Edulink_Student_Staff_WPF_DB"
        mc:Ignorable="d"
        Title="Edulink Student's &amp; Staff" Height="480" Width="720">
    <!-- up the resources (colours & styling) to be used in designing the WPF -->
    <Window.Resources>
        <SolidColorBrush x:Key="PrimaryBlueBrush" Color="#2563EB"/>
        <SolidColorBrush x:Key="PrimaryBlueDarkBrush" Color="#1D4ED8"/>
        <SolidColorBrush x:Key="AccentBlueBrush" Color="#DBEAFE"/>
        <SolidColorBrush x:Key="PanelBrush" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="BorderBrushBlue" Color="#BFDBFE"/>
        <SolidColorBrush x:Key="TextBrushMain" Color="#1E293B"/>
        <SolidColorBrush x:Key="TextBrushMuted" Color="#475569"/>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextBrushMain}"/>
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="{StaticResource PrimaryBlueBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource PrimaryBlueBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border CornerRadius="8"
                        Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center"
                                      VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource PrimaryBlueDarkBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>
    <Grid Margin="28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock Text="Edulink Student and Staff Management System"
                       FontSize="25"
                       FontFamily="Bauhaus 93"
                       FontWeight="SemiBold"/>
            <TextBlock Text="Choose the form you would like to open below"
                       Margin="0,8,0,0"
                       FontFamily="Century Gothic"
                       FontWeight="SemiBold"/>
        </StackPanel>

        <Grid Grid.Row="1" Margin="0,24,0,24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>

            <!-- Staff Section -->
            <Border Grid.Column="0"
                    Margin="0,0,12,0"
                    Padding="24"
                    Background="{StaticResource PanelBrush}"
                    BorderBrush="{StaticResource BorderBrushBlue}"
                    BorderThickness="1"
                    CornerRadius="15">
                <StackPanel>
                    <TextBlock Text="Staff Management"
                               FontSize="22"
                               FontWeight="SemiBold"
                               FontFamily="Bauhaus 93"/>
                    <TextBlock Text="Open the Staff Form to load staff details, search them and perform CRUD operations."
                               TextWrapping="Wrap"
                               Margin="0,10,0,18"
                               Foreground="{StaticResource TextBrushMuted}"
                               FontFamily="Century Gothic"/>
                    <Button Content="Open Staff Form"
                            Width="150"
                            Height="40"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Click="btnStaff_Click"/>
                </StackPanel>
            </Border>


            <!-- Student Section -->

            <Border Grid.Column="1"
                 Margin="12,0,0,0"
                 Padding="22"
                 Background="{StaticResource PanelBrush}"
                 BorderBrush="{StaticResource BorderBrushBlue}"
                 BorderThickness="1"
                 CornerRadius="15">
                <StackPanel>
                    <TextBlock Text="Student Management"
                        FontSize="22"
                        FontWeight="SemiBold"
                        FontFamily="Bauhaus 93"/>
                    <TextBlock Text="Open the Student Form to load student details, search them and perform CRUD operations."
                        TextWrapping="Wrap"
                        Margin="0,10,0,18"
                        Foreground="{StaticResource TextBrushMuted}"
                        FontFamily="Century Gothic"/>
                    <Button Content="Open Student Form"
                     Width="150"
                     Height="40"
                     Style="{StaticResource PrimaryButtonStyle}"
                     Click="btnStudent_Click"/>
                </StackPanel>
            </Border>
        </Grid>

    </Grid>
</Window>
