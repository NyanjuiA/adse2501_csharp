<Window x:Class="Edulink_Student_Staff_WPF_DB.StaffWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:local="clr-namespace:Edulink_Student_Staff_WPF_DB"
        mc:Ignorable="d"
        Title="Staff Management" Height="600" Width="800"
        WindowStartupLocation="CenterOwner"
        Background="#f3f8ff">
    <!-- Styles and resources to be used on the student's form -->
    <Window.Resources>
        <SolidColorBrush x:Key="PrimaryBlueBrush" Color="#2563EB" />
        <SolidColorBrush x:Key="PrimaryBlueDarkBrush" Color="#1D4ED8" />
        <SolidColorBrush x:Key="AccentBlueBrush" Color="#DBEAFE" />
        <SolidColorBrush x:Key="PanelBrush" Color="#FFFFFF" />
        <SolidColorBrush x:Key="BorderBrushBlue" Color="#BFDBFE" />
        <SolidColorBrush x:Key="TextBrushMain" Color="#1E293B" />
        <SolidColorBrush x:Key="TextBrushMuted" Color="#475569" />

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextBrushMain}" />
            <Setter Property="FontSize" Value="13" />
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Padding" Value="8,6" />
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushBlue}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{StaticResource TextBrushMain}" />
        </Style>

        <Style TargetType="DatePicker">
            <Setter Property="Padding" Value="6,3" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushBlue}" />
            <Setter Property="Foreground" Value="{StaticResource TextBrushMain}" />
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Background" Value="{StaticResource PrimaryBlueBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource PrimaryBlueBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="12,7" />
            <Setter Property="Margin" Value="5" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border CornerRadius="8"
                            Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource PrimaryBlueDarkBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
            <Setter Property="Background" Value="{StaticResource AccentBlueBrush}" />
            <Setter Property="Foreground" Value="{StaticResource PrimaryBlueDarkBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushBlue}" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#BFDBFE" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Border Grid.Row="0"
             Background="{StaticResource PanelBrush}"
             BorderBrush="{StaticResource BorderBrushBlue}"
             BorderThickness="1"
             CornerRadius="12"
             Padding="8">
            <StackPanel Orientation="Horizontal">
                <TextBox Width="250"
                      Margin="5"
                      ToolTip="Search by Name, Course, or Nationality"
                      Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"/>
                <Button Content="New" Width="90" Style="{StaticResource SecondaryButtonStyle}"
                    Click="btnNew_Click"/>
                <Button Content="Refresh" Width="90" Style="{StaticResource SecondaryButtonStyle}"
                    Click="btnRefresh_Click"/>
            </StackPanel>
        </Border>
        <Border Grid.Row="1"
             Margin="0,10,0,0"
             Background="{StaticResource PanelBrush}"
             BorderBrush="{StaticResource BorderBrushBlue}"
             BorderThickness="1"
             CornerRadius="12"
             Padding="8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Margin="5,5,5,0" FontWeight="SemiBold" Text="Name"/>
                    <TextBox Margin="5" Text="{Binding SelectedStaff.Names}"/>

                    <TextBlock Margin="5,5,5,0" FontWeight="SemiBold" Text="Staff ID"/>
                    <TextBox Margin="5" Text="{Binding SelectedStaff.StaffID}"/>

                    <TextBlock Margin="5,5,5,0" FontWeight="SemiBold" Text="Birth Date"/>
                    <TextBox Margin="5" Text="{Binding SelectedStaff.BirthDate}"/>

                    <TextBlock Margin="5,5,5,0" FontWeight="SemiBold" Text="Gender"/>
                    <TextBox Margin="5" Text="{Binding SelectedStaff.Gender}"/>

                    <TextBlock Margin="5,5,5,0" FontWeight="SemiBold" Text="Designation"/>
                    <TextBox Margin="5" Text="{Binding SelectedStaff.Designation}"/>
                </StackPanel>
                <StackPanel Grid.Column="1">
                  <TextBlock Margin="5,5,5,0" FontWeight="SemiBold" Text="Employment Date"/>
                    <TextBox Margin="5" Text="{Binding SelectedStaff.EmploymentDate}"/> 
                    
                    <TextBlock Margin="5,5,5,0" FontWeight="SemiBold" Text="Phone No."/>
                    <TextBox Margin="5" Text="{Binding SelectedStaff.PhoneNo}"/> 
                    
                    <TextBlock Margin="5,5,5,0" FontWeight="SemiBold" Text="Email"/>
                    <TextBox Margin="5" Text="{Binding SelectedStaff.Email}"/>     
                    
                    <TextBlock Margin="5,5,5,0" FontWeight="SemiBold" Text="Nationality"/>
                    <TextBox Margin="5" Text="{Binding SelectedStaff.Nationality}"/>

                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="2"
             Margin="0,10,0,0"
             Background="{StaticResource PanelBrush}"
             BorderBrush="{StaticResource BorderBrushBlue}"
             BorderThickness="1"
             CornerRadius="12"
             Padding="5">
            <DataGrid ItemsSource="{Binding StaffView}"
                   SelectedItem="{Binding SelectedStaff}"
                   AutoGenerateColumns="False"
                   Margin="5"
                   HeadersVisibility="Column"
                   GridLinesVisibility="Horizontal"
                   RowBackground="White"
                   AlternatingRowBackground="#Eff5ff"
                   BorderThickness="0"
                   Background="Transparent"
                   Foreground="{StaticResource TextBrushMain}"
                   HorizontalGridLinesBrush="#DBEAFE"
                   VerticalGridLinesBrush="#DBEAFE">
                <DataGrid.ColumnHeaderStyle>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="#E0ECFF"/>
                        <Setter Property="Foreground" Value="{StaticResource PrimaryBlueDarkBrush}"/>
                        <Setter Property="FontWeight" Value="SemiBold"/>
                        <Setter Property="Padding" Value="8,6"/>
                        <Setter Property="BorderBrush" Value="#BFDBFE"/>
                        <Setter Property="BorderThickness" Value="0,0,0,1"/>
                    </Style>
                </DataGrid.ColumnHeaderStyle>
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Staff ID" Binding="{Binding StaffID}"/>
                    <DataGridTextColumn Header="Name(s)" Binding="{Binding Names}"/>
                    <DataGridTextColumn Header="Birth Date" Binding="{Binding BirthDate, StringFormat=d}"/>
                    <DataGridTextColumn Header="Gender" Binding="{Binding Gender}"/>
                    <DataGridTextColumn Header="Email" Binding="{Binding Email}"/>
                    <DataGridTextColumn Header="Nationality" Binding="{Binding Nationality}"/>
                    <DataGridTextColumn Header="EmploymentDate" Binding="{Binding EmploymentDate, StringFormat=d}"/>
                    <DataGridTextColumn Header="Designation" Binding="{Binding Designation}"/>
                    <DataGridTextColumn Header="Phone Number" Binding="{Binding PhoneNo}"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,0">
            <Button Content="Add" Width="90" Style="{StaticResource PrimaryButtonStyle}"
         Click="btnAdd_Click"/>
            <Button Content="Update" Width="90" Style="{StaticResource PrimaryButtonStyle}"
         Click="btnUpdate_Click"/>
            <Button Content="Delete" Width="90" Style="{StaticResource PrimaryButtonStyle}"
         Click="btnDelete_Click"/>
            <Button Content="|&lt;" Width="55" Style="{StaticResource SecondaryButtonStyle}"
         Click="btnFirst_Click"/>
            <Button Content="&lt;" Width="55" Style="{StaticResource SecondaryButtonStyle}"
         Click="btnPrevious_Click"/>
            <Button Content="&gt;" Width="55" Style="{StaticResource SecondaryButtonStyle}"
         Click="btnNext_Click"/>
            <Button Content="&gt;|" Width="55" Style="{StaticResource SecondaryButtonStyle}"
         Click="btnLast_Click"/>
        </StackPanel>

        <TextBlock Grid.Row="4"
                Foreground="{StaticResource TextBrushMuted}"
                Text="{Binding StatusMessage}"
                TextWrapping="Wrap"
                Margin="5"/>

    </Grid>
</Window>
